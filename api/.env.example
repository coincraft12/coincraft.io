NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://coincraft:password@localhost:5432/coincraft_dev
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=coincraft-dev-access-secret-32-chars-minimum
JWT_REFRESH_SECRET=coincraft-dev-refresh-secret-32-chars-minimum
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# Frontend
FRONTEND_URL=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:4000/auth/kakao/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:4000/auth/naver/callback

# Payment — PortOne
PORTONE_API_SECRET=
PORTONE_STORE_ID=
PORTONE_WEBHOOK_SECRET=

# Storage — Hetzner Object Storage (S3-compatible)
STORAGE_PROVIDER=hetzner
STORAGE_ENDPOINT=https://fsn1.your-objectstorage.com
STORAGE_REGION=fsn1
STORAGE_BUCKET=coincraft-media
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# Storage — Cloudflare R2 (legacy, kept for migration reference)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=coincraft-media

# Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@coincraft.io

# Video
VIMEO_ACCESS_TOKEN=

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Monitoring
SENTRY_DSN=

# x402 Payment
X402_PAYMENT_ADDRESS=
X402_SUPPORTED_CHAIN=base

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

SOLAPI_API_KEY=
SOLAPI_API_SECRET=

# Admin SMTP (관리자 알림 메일)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=coincraft.edu@gmail.com
SMTP_PASS=
ADMIN_EMAIL=coincraft.edu@gmail.com
